{
  "name": "buddy-studio",
  "version": "0.1.0",
  "description": "Wizard-style CLI/TUI for generating and applying custom Claude Code buddy profiles.",
  "type": "module",
  "bin": {
    "buddy-studio": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "studio": "tsx src/index.ts",
    "dev": "tsx src/index.ts help",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
